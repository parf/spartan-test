#!/bin/bash

set -o pipefail

#
# HELP

usage() {
  echo "Usage: stest-all [OPTION...] [TOP-DIRECTORY]"
  echo "execute executable tests in current or given directory (and subdirectories) in parallel"
  echo
  echo Options
  echo "  --list          : list selected tests instead of executing them"
  echo "  --all           : include non-executable .stest files"
  echo "  --tag=prod      : select any requested tag; repeat or separate with comma/space"
  echo "  --tag='prod -long': select prod tests, excluding tests tagged long"
  echo "                     tests with @require-tag need an explicit positive match"
  echo "  --recent        : select tests changed in the last 1 day"
  echo "  --recent=2day   : select tests changed in the last 2 days"
  echo "  --new           : select the newest test after other filters"
  echo "  --new=4         : select the 4 newest tests after other filters"
#  echo " -v  : verbose - show test names"   << DEFAULT
  echo "  -q              : quiet - show only errors; test selection is unchanged"
}

recent_minutes() {
  local v="${1:-1day}"
  case "$v" in
    *day) echo $(( ${v%day} * 1440 )) ;;
    *days) echo $(( ${v%days} * 1440 )) ;;
    *) echo $(( v * 1440 )) ;;
  esac
}

discover_tests() {
  local find_args=(-name "*.stest")
  if [[ $all != 1 ]]; then
    find_args+=(-executable)
  fi
  if [[ -n "$recent" ]]; then
    find_args+=(-mmin "-$(recent_minutes "$recent")")
  fi

  find . "${find_args[@]}"
}

valid_tag() {
  [[ $1 =~ ^[[:alnum:]][[:alnum:]_.:-]*$ ]]
}

add_tag_tokens() {
  local definition=$1
  local source=$3
  local token
  local -a tokens
  local -n destination=$2

  definition=${definition//,/ }
  read -r -a tokens <<< "$definition"
  if [[ ${#tokens[@]} == 0 ]]; then
    echo "$source: tag list cannot be empty" >&2
    return 2
  fi
  for token in "${tokens[@]}"; do
    if ! valid_tag "$token"; then
      echo "$source: invalid tag '$token'" >&2
      return 2
    fi
    # shellcheck disable=SC2034 # assignment writes through the destination nameref
    destination["$token"]=1
  done
}

parse_tag_selectors() {
  local definition token
  local -a tokens

  for definition in "${tag_filters[@]}"; do
    definition=${definition//,/ }
    read -r -a tokens <<< "$definition"
    if [[ ${#tokens[@]} == 0 ]]; then
      echo "--tag expects at least one tag" >&2
      return 2
    fi
    for token in "${tokens[@]}"; do
      if [[ $token == -* ]]; then
        token=${token#-}
        if ! valid_tag "$token"; then
          echo "--tag: invalid excluded tag '-$token'" >&2
          return 2
        fi
        excluded_tags["$token"]=1
      else
        if ! valid_tag "$token"; then
          echo "--tag: invalid tag '$token'" >&2
          return 2
        fi
        requested_tags["$token"]=1
      fi
    done
  done
}

file_matches_tags() {
  local file=$1
  local line directive definition token
  local line_number=0
  local required_match=0
  local positive_match=0
  local -A normal_tags=()
  local -A required_tags=()
  local -A file_tags=()

  if ! exec 3< "$file"; then
    echo "Unable to read test file: $file" >&2
    return 2
  fi
  while (( line_number < 4 )) && IFS= read -r line <&3; do
    ((line_number++))
    if [[ $line =~ ^[[:space:]]*#[[:space:]]*@(tag|require-tag)([[:space:]]+(.*))?$ ]]; then
      directive=${BASH_REMATCH[1]}
      definition=${BASH_REMATCH[3]}
      if [[ $directive == tag ]]; then
        add_tag_tokens "$definition" normal_tags "$file:$line_number" || {
          exec 3<&-
          return 2
        }
      else
        add_tag_tokens "$definition" required_tags "$file:$line_number" || {
          exec 3<&-
          return 2
        }
      fi
    fi
  done
  exec 3<&-

  for token in "${!normal_tags[@]}" "${!required_tags[@]}"; do
    [[ -n $token ]] && file_tags["$token"]=1
  done

  for token in "${!excluded_tags[@]}"; do
    [[ ${file_tags[$token]+yes} ]] && return 1
  done

  if (( ${#required_tags[@]} > 0 )); then
    for token in "${!required_tags[@]}"; do
      if [[ ${requested_tags[$token]+yes} ]]; then
        required_match=1
        break
      fi
    done
    (( required_match == 1 )) || return 1
  fi

  if (( ${#requested_tags[@]} > 0 )); then
    for token in "${!requested_tags[@]}"; do
      if [[ ${file_tags[$token]+yes} ]]; then
        positive_match=1
        break
      fi
    done
    (( positive_match == 1 )) || return 1
  fi

  return 0
}

filter_tagged_tests() {
  local file status

  while IFS= read -r file; do
    file_matches_tags "$file"
    status=$?
    case $status in
      0) printf '%s\n' "$file" ;;
      1) ;;
      *) return "$status" ;;
    esac
  done
}

list_tests() {
  local file mtime

  if [[ -n "$new" ]]; then
    discover_tests | filter_tagged_tests | while IFS= read -r file; do
      mtime=$(stat -c '%y' "$file") || return
      printf '%s %s\n' "$mtime" "$file"
    done | sort -r | sed -n "1,${new}p" | cut -d " " -f 4-
  else
    discover_tests | filter_tagged_tests
  fi
}

quiet=0
list=0
all=0
recent=
new=
dir=
tag_filters=()
declare -A requested_tags=()
declare -A excluded_tags=()
stest_bin="$(cd "$(dirname "$0")" && pwd)/stest"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      exit 1
      ;;
    --list)
      list=1
      ;;
    --all)
      all=1
      ;;
    --tag=*)
      tag_filters+=("${1#--tag=}")
      ;;
    --tag)
      echo "--tag requires a value, e.g. --tag='prod -long'" >&2
      exit 1
      ;;
    -q)
      quiet=1
      ;;
    --recent)
      recent=1day
      ;;
    --recent=*)
      recent="${1#--recent=}"
      ;;
    --new)
      new=1
      ;;
    --new=*)
      new="${1#--new=}"
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$dir" ]]; then
        echo "Unexpected argument: $1" >&2
        usage >&2
        exit 1
      fi
      dir="$1"
      ;;
  esac
  shift
done

parse_tag_selectors || exit $?

if [[ -n "$new" && ! "$new" =~ ^[1-9][0-9]*$ ]]; then
  echo "--new expects a positive integer" >&2
  exit 1
fi

if [[ -n "$recent" && ! "$recent" =~ ^[1-9][0-9]*(day|days)?$ ]]; then
  echo "--recent expects a positive number of days, e.g. --recent=2day" >&2
  exit 1
fi

if [[ -n "$dir" ]]; then
  cd "$dir" || exit 1
fi

if [[ $list == 1 ]]; then
  list_tests
  exit $?
fi

# check for GNU parallel
[[ $(type -P parallel) ]] || { echo "GNU parallel required"; exit 1; }

test_list=$(mktemp "${TMPDIR:-/tmp}/stest-all.XXXXXX") || exit 1
trap 'rm -f "$test_list"' EXIT
list_tests > "$test_list"
status=$?
if (( status != 0 )); then
  exit "$status"
fi

# show errors only (in STDERR)
if [[ $quiet == 1 ]]; then
  parallel -j0 "$stest_bin {} -q" :::: "$test_list"
  exit $?
fi

parallel -j0 "echo {}; $stest_bin {} --color" :::: "$test_list"
exit $?
