#!/usr/bin/env stest
# stest and stest-all must expose failures through process exit status.

; $self = realpath(\stest\i('stest')->file);
; $root = realpath(dirname($self, 3));
; $tmp = sys_get_temp_dir() . "/stest-exit-status-" . getmypid();
; exec("rm -rf " . escapeshellarg($tmp));
; mkdir($tmp, 0777, true);
; register_shutdown_function(function () use ($tmp) {
    exec("rm -rf " . escapeshellarg($tmp));
  });
; $pass = "$tmp/pass.stest";
; $fail = "$tmp/fail.stest";
; $generateFail = "$tmp/generate-fail.stest";
; $passText = "#!/usr/bin/env stest\n1+1;\n    2;\n";
; $failText = "#!/usr/bin/env stest\n1+1;\n    3;\n";
; file_put_contents($pass, $passText);
; file_put_contents($fail, $failText);
; file_put_contents($generateFail, $failText);
; chmod($pass, 0755);
; chmod($fail, 0755);
; chmod($generateFail, 0755);
; $bin = escapeshellarg($root . "/bin/stest");
; $all = escapeshellarg($root . "/bin/stest-all");
; $path = "PATH=" . escapeshellarg($root . "/bin:" . getenv("PATH"));
; $run = function (string $cmd): int {
    $out = [];
    exec($cmd . " >/dev/null 2>&1", $out, $code);
    return $code;
  };

$run("$bin " . escapeshellarg($pass));
    0;

$run("$bin " . escapeshellarg($fail)) !== 0;
    true;

$run("$bin " . escapeshellarg($fail) . " -s") !== 0;
    true;

$run("$bin " . escapeshellarg($fail) . " -q") !== 0;
    true;

$run("$bin --help 2>&1 | grep -q -- '-s, -q'");
    0;

$run("$bin " . escapeshellarg($fail) . " --cron") !== 0;
    true;

$run("$bin " . escapeshellarg($generateFail) . " --generate");
    0;

$run("$bin " . escapeshellarg("$tmp/missing.stest")) !== 0;
    true;

# --generate intentionally remains successful even when an input cannot be read.
$run("$bin " . escapeshellarg("$tmp/missing.stest") . " --generate");
    0;

; $setupWarning = "$tmp/setup-warning.stest";
; file_put_contents($setupWarning, "#!/usr/bin/env stest\n; trigger_error(\"setup broken\", E_USER_WARNING);\n");
; chmod($setupWarning, 0755);

$run("$bin " . escapeshellarg($setupWarning) . " -q") !== 0;
    true;

; $warningStop = "$tmp/warning-stop.stest";
; $warningStopLog = "$tmp/warning-stop.stderr";
; $warningStopText = "#!/usr/bin/env stest\n"
    . "; trigger_error(\"ignored before stop\", E_USER_WARNING); STest::stop(\"skip\");\n";
; file_put_contents($warningStop, $warningStopText);
; chmod($warningStop, 0755);
; exec(
    "$bin " . escapeshellarg($warningStop) . " " . escapeshellarg($pass)
      . " -q >/dev/null 2>" . escapeshellarg($warningStopLog),
    $warningStopOutput,
    $warningStopCode
  );

$warningStopCode;
    0;

file_get_contents($warningStopLog);
    '';

; $failThenStop = "$tmp/fail-then-stop.stest";
; $failThenStopText = "#!/usr/bin/env stest\n"
    . "1+1;\n"
    . "    3;\n"
    . "; STest::stop(\"after failure\");\n";
; file_put_contents($failThenStop, $failThenStopText);
; chmod($failThenStop, 0755);

$run("$bin " . escapeshellarg($failThenStop) . " -q") !== 0;
    true;

$run("$bin " . escapeshellarg($fail) . " --first_error -q") !== 0;
    true;

; $reporterDir = "$tmp/reporter";
; $reporterMarker = "$reporterDir/result";
; mkdir($reporterDir);
; $reporterInit = "<?php\n"
    . "class ExitStatusReporter extends \\stest\\helper\\Reporter {\n"
    . "  function stop(string \$test, array \$stats = []) { file_put_contents("
    . var_export($reporterMarker, true) . ", 'stop'); }\n"
    . "  function fail(string \$test, array \$stats = []) { file_put_contents("
    . var_export($reporterMarker, true) . ", 'fail'); }\n"
    . "}\n";
; file_put_contents("$reporterDir/reporter-init.php", $reporterInit);
; file_put_contents(
    "$reporterDir/stest-config.json",
    json_encode(['init' => 'reporter-init.php', 'reporter' => 'ExitStatusReporter'])
  );
; file_put_contents("$reporterDir/fail-stop.stest", $failThenStopText);
; chmod("$reporterDir/fail-stop.stest", 0755);

$run("$bin " . escapeshellarg("$reporterDir/fail-stop.stest") . " -q") !== 0;
    true;

file_get_contents($reporterMarker);
    'fail';

; file_put_contents("$reporterDir/stop.stest", "#!/usr/bin/env stest\n; STest::stop('skip');\n");
; chmod("$reporterDir/stop.stest", 0755);

$run("$bin " . escapeshellarg("$reporterDir/stop.stest") . " -q");
    0;

file_get_contents($reporterMarker);
    'stop';

; $futureMarker = "$tmp/future-stop-ran";
; $futureStop = "$tmp/future-stop.stest";
; $futureStopText = "#!/usr/bin/env stest\n"
    . "; STest::stop(\"disabled\", 29990101);\n"
    . "; file_put_contents(" . var_export($futureMarker, true) . ", \"ran\");\n";
; file_put_contents($futureStop, $futureStopText);
; chmod($futureStop, 0755);

$run("$bin " . escapeshellarg($futureStop));
    0;

file_exists($futureMarker);
    false;

; $expiredMarker = "$tmp/expired-stop-ran";
; $expiredStop = "$tmp/expired-stop.stest";
; $expiredStopText = "#!/usr/bin/env stest\n"
    . "; STest::stop(\"expired\", 20000101);\n"
    . "; file_put_contents(" . var_export($expiredMarker, true) . ", \"ran\");\n";
; file_put_contents($expiredStop, $expiredStopText);
; chmod($expiredStop, 0755);

$run("$bin " . escapeshellarg($expiredStop));
    0;

file_get_contents($expiredMarker);
    'ran';

; $readOnly = "$tmp/read-only.stest";
; $readOnlyText = "#!/usr/bin/env stest\n1+1;\n";
; file_put_contents($readOnly, $readOnlyText);
; chmod($readOnly, 0444);

$run("$bin " . escapeshellarg($readOnly) . " -q") !== 0;
    true;

file_get_contents($readOnly) === $readOnlyText;
    true;

; chmod($readOnly, 0644);
; $atomicSave = "$tmp/atomic-save.stest";
; file_put_contents($atomicSave, "#!/usr/bin/env stest\n1+1;\n");
; chmod($atomicSave, 0755);

$run("$bin " . escapeshellarg($atomicSave));
    0;

fileperms($atomicSave) & 0777;
    493;

str_contains(file_get_contents($atomicSave), "    2;\n");
    true;

$run("cd " . escapeshellarg($tmp) . " && $path ./pass.stest");
    0;

$run("cd " . escapeshellarg($tmp) . " && $path ./fail.stest") !== 0;
    true;

; $passDir = "$tmp/pass-dir";
; $mixedDir = "$tmp/mixed-dir";
; mkdir($passDir);
; mkdir($mixedDir);
; copy($pass, "$passDir/pass.stest");
; copy($pass, "$mixedDir/pass.stest");
; copy($fail, "$mixedDir/fail.stest");
; chmod("$passDir/pass.stest", 0755);
; chmod("$mixedDir/pass.stest", 0755);
; chmod("$mixedDir/fail.stest", 0755);

$run("$path $all " . escapeshellarg($passDir));
    0;

$run("$path $all " . escapeshellarg($mixedDir)) !== 0;
    true;

; $fakeBin = "$tmp/fake-bin";
; mkdir($fakeBin);
; $discoveryMarker = "$tmp/discovery-test-ran";
; $discoveryTest = "$passDir/discovery-marker.stest";
; $discoveryTestText = "#!/usr/bin/env stest\n"
    . "; file_put_contents(" . var_export($discoveryMarker, true) . ", \"ran\");\n"
    . "1;\n    1;\n";
; file_put_contents($discoveryTest, $discoveryTestText);
; chmod($discoveryTest, 0755);
; file_put_contents("$fakeBin/fd", "#!/bin/sh\necho ./discovery-marker.stest\necho '[fd error]: forced-fd-error' >&2\nexit 0\n");
; chmod("$fakeBin/fd", 0755);
; $discoveryFailurePath = "PATH=" . escapeshellarg($fakeBin . ":" . $root . "/bin:" . getenv("PATH"));

$run("$discoveryFailurePath $all -q " . escapeshellarg($passDir)) !== 0;
    true;

file_exists($discoveryMarker);
    false;

; $recentDir = "$tmp/recent-dir";
; mkdir($recentDir);
; copy($pass, "$recentDir/current-pass.stest");
; copy($fail, "$recentDir/thirty-hours-fail.stest");
; chmod("$recentDir/current-pass.stest", 0755);
; chmod("$recentDir/thirty-hours-fail.stest", 0755);
; touch("$recentDir/thirty-hours-fail.stest", time() - 30 * 60 * 60);

$run("$path $all --recent " . escapeshellarg($recentDir));
    0;

$run("$path $all --recent=2day " . escapeshellarg($recentDir)) !== 0;
    true;

; $newDir = "$tmp/new-dir";
; mkdir($newDir);
; copy($fail, "$newDir/older-fail.stest");
; copy($pass, "$newDir/newer-pass.stest");
; chmod("$newDir/older-fail.stest", 0755);
; chmod("$newDir/newer-pass.stest", 0755);
; touch("$newDir/older-fail.stest", time() - 60);
; touch("$newDir/newer-pass.stest", time());

$run("$path $all --new " . escapeshellarg($newDir));
    0;

$run("$path $all --new=2 " . escapeshellarg($newDir)) !== 0;
    true;

; $allDir = "$tmp/all-dir";
; mkdir($allDir);
; copy($pass, "$allDir/exec-pass.stest");
; copy($fail, "$allDir/nonexec-fail.stest");
; chmod("$allDir/exec-pass.stest", 0755);
; chmod("$allDir/nonexec-fail.stest", 0644);
; touch("$allDir/exec-pass.stest", time() - 60);
; touch("$allDir/nonexec-fail.stest", time());

$run("$path $all --list " . escapeshellarg($allDir) . " | grep -q './nonexec-fail.stest'") !== 0;
    true;

$run("$path $all --list --all " . escapeshellarg($allDir) . " | grep -q './nonexec-fail.stest'");
    0;

$run("$path $all " . escapeshellarg($allDir));
    0;

$run("$path $all --all " . escapeshellarg($allDir)) !== 0;
    true;

$run("$path $all -q " . escapeshellarg($allDir));
    0;

$run("$path $all --all -q " . escapeshellarg($allDir)) !== 0;
    true;

$run("$path $all --list --all --new " . escapeshellarg($allDir) . " | grep -q './nonexec-fail.stest'");
    0;

; $reflectionDeprecated = "$tmp/reflection-deprecated.stest";
; $reflectionDeprecatedText = "#!/usr/bin/env stest\n"
    . "; set_error_handler(function (\$level, \$message, \$file, \$line) {\n"
    . "    throw new ErrorException(\$message, 0, \$level, \$file, \$line);\n"
    . "  });\n"
    . "(function () { \$m = new ReflectionMethod(DateTime::class, \"format\"); \$m->setAccessible(true); return 1; })();\n"
    . "    1;\n";
; file_put_contents($reflectionDeprecated, $reflectionDeprecatedText);
; chmod($reflectionDeprecated, 0755);

$run("$bin " . escapeshellarg($reflectionDeprecated));
    0;
